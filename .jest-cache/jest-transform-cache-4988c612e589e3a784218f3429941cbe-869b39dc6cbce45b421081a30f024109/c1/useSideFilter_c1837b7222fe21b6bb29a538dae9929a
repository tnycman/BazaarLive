      sourcesContent: ["/**\n * Side Filter Hook\n * Enterprise-grade hook for side filter functionality\n * 100% best practices, zero shortcuts, enterprise-grade patterns\n */\n\nimport { useCallback, useEffect, useMemo, useState } from 'react';\nimport { SideFilterDataService } from '@/services/filtering/SideFilterDataService';\nimport { useUnifiedFilterState } from '@/hooks/useUnifiedFilterState';\nimport { useConfiguration } from '@/hooks/useConfiguration';\nimport { FilterErrorHandler, FilterErrorType, FilterErrorSeverity, FilterErrorContext } from '@/services/error/FilterErrorHandler';\nimport { MemoryManagementService } from '@/services/memory/MemoryManagementService';\nimport type { SideFilterSection, SideFilterOption } from '@/components/filters/AdvancedSideFilter';\n\n// ===== HOOK INTERFACES =====\n\nexport interface UseSideFilterOptions {\n  readonly categoryId: string;\n  readonly subscriberId?: string;\n  readonly enableErrorHandling?: boolean;\n  readonly enableMemoryManagement?: boolean;\n  readonly enableAnalytics?: boolean;\n  readonly enablePresets?: boolean;\n  readonly autoLoadData?: boolean;\n  readonly onError?: (error: Error) => void;\n  readonly onDataLoaded?: (sections: SideFilterSection[]) => void;\n  readonly onFilterChange?: (sectionId: string, selectedValues: string[]) => void;\n  readonly onSectionToggle?: (sectionId: string, isExpanded: boolean) => void;\n}\n\nexport interface UseSideFilterReturn {\n  // Data\n  readonly sections: SideFilterSection[];\n  readonly isLoading: boolean;\n  readonly error: Error | null;\n  readonly isDataInitialized: boolean;\n  readonly dataVersion: string | null;\n  readonly statistics: Record<string, any>;\n\n  // State\n  readonly appliedFilters: Record<string, string[]>;\n  readonly expandedSections: Set<string>;\n  readonly searchQueries: Record<string, string>;\n  readonly sortOrders: Record<string, 'asc' | 'desc' | 'count'>;\n  readonly selectedPreset?: string;\n  readonly isDirty: boolean;\n  readonly lastUpdateTime: number;\n\n  // Actions\n  readonly loadFilterData: (categoryId?: string) => Promise<boolean>;\n  readonly updateFilterSections: (sections: SideFilterSection[]) => void;\n  readonly updateFilterOptions: (sectionId: string, options: SideFilterOption[]) => void;\n  readonly applyFilter: (sectionId: string, selectedValues: string[]) => void;\n  readonly clearFilter: (sectionId: string) => void;\n  readonly clearAllFilters: () => void;\n  readonly toggleSection: (sectionId: string, isExpanded?: boolean) => void;\n  readonly updateSearchQuery: (sectionId: string, query: string) => void;\n  readonly updateSortOrder: (sectionId: string, order: 'asc' | 'desc' | 'count') => void;\n  readonly savePreset: (name: string) => string | null;\n  readonly loadPreset: (presetId: string) => boolean;\n  readonly exportData: (categoryId?: string) => string;\n  readonly importData: (data: string) => boolean;\n  readonly clearError: () => void;\n  readonly refreshData: () => Promise<void>;\n}\n\n// ===== SIDE FILTER HOOK =====\n\nexport const useSideFilter = (options: UseSideFilterOptions): UseSideFilterReturn => {\n  const {\n    categoryId,\n    subscriberId = `side-filter-${categoryId}`,\n    enableErrorHandling = true,\n    enableMemoryManagement = true,\n    enableAnalytics = true,\n    enablePresets = true,\n    autoLoadData = true,\n    onError,\n    onDataLoaded,\n    onFilterChange,\n    onSectionToggle\n  } = options;\n\n  // ===== STATE MANAGEMENT =====\n\n  const [sections, setSections] = useState<SideFilterSection[]>([]);\n  const [isLoading, setIsLoading] = useState<boolean>(false);\n  const [error, setError] = useState<Error | null>(null);\n  const [isDataInitialized, setIsDataInitialized] = useState<boolean>(false);\n  const [dataVersion, setDataVersion] = useState<string | null>(null);\n  const [statistics, setStatistics] = useState<Record<string, any>>({});\n\n  const [appliedFilters, setAppliedFilters] = useState<Record<string, string[]>>({});\n  const [expandedSections, setExpandedSections] = useState<Set<string>>(new Set());\n  const [searchQueries, setSearchQueries] = useState<Record<string, string>>({});\n  const [sortOrders, setSortOrders] = useState<Record<string, 'asc' | 'desc' | 'count'>>({});\n  const [selectedPreset, setSelectedPreset] = useState<string | undefined>(undefined);\n  const [isDirty, setIsDirty] = useState<boolean>(false);\n  const [lastUpdateTime, setLastUpdateTime] = useState<number>(Date.now());\n\n  // ===== SERVICE INSTANCES =====\n\n  const dataService = useMemo(() => SideFilterDataService.getInstance(), []);\n  const errorHandler = useMemo(() => FilterErrorHandler.getInstance(), []);\n  const memoryManager = useMemo(() => MemoryManagementService.getInstance(), []);\n\n  // ===== UNIFIED FILTER STATE =====\n\n  const {\n    state: filterState,\n    updateState,\n    clearFilters,\n    hasAppliedFilters,\n    appliedFiltersCount,\n    isLoading: filterLoading,\n    error: filterError,\n    clearError: clearFilterError,\n    savePreset: saveUnifiedPreset,\n    loadPreset: loadUnifiedPreset,\n    undo,\n    analytics\n  } = useUnifiedFilterState({\n    subscriberId: `${subscriberId}-unified`,\n    enableErrorHandling,\n    enableMemoryManagement,\n    enableAnalytics,\n    enablePresets,\n    onError\n  });\n\n  // ===== CONFIGURATION =====\n\n  const {\n    configuration: config,\n    updateConfiguration\n  } = useConfiguration({\n    subscriberId: `${subscriberId}-config`\n  });\n\n  // ===== COMPUTED VALUES =====\n\n  const totalAppliedFilters = useMemo(() => {\n    return Object.values(appliedFilters).reduce((sum, values) => sum + values.length, 0);\n  }, [appliedFilters]);\n\n  const hasChanges = useMemo(() => {\n    return isDirty || hasAppliedFilters;\n  }, [isDirty, hasAppliedFilters]);\n\n  // ===== EVENT HANDLERS =====\n\n  const handleError = useCallback((error: Error) => {\n    setError(error);\n    if (onError) {\n      onError(error);\n    }\n  }, [onError]);\n\n  const handleDataLoaded = useCallback((loadedSections: SideFilterSection[]) => {\n    setSections(loadedSections);\n    setIsDataInitialized(true);\n    setDataVersion(dataService.getDataVersion(categoryId));\n    setStatistics(dataService.getFilterStatistics());\n\n    if (onDataLoaded) {\n      onDataLoaded(loadedSections);\n    }\n  }, [categoryId, dataService, onDataLoaded]);\n\n  const handleFilterChange = useCallback((sectionId: string, selectedValues: string[]) => {\n    try {\n      setAppliedFilters(prev => ({\n        ...prev,\n        [sectionId]: selectedValues\n      }));\n      setIsDirty(true);\n      setLastUpdateTime(Date.now());\n\n      // Update unified filter state\n      const section = sections.find(s => s.id === sectionId);\n      if (section) {\n        const updates: Record<string, string[]> = {};\n        \n        switch (section.type) {\n          case 'checkbox':\n          case 'radio':\n          case 'range':\n          case 'color':\n          case 'size':\n            updates[`selected${section.title.replace(/\\s+/g, '')}`] = selectedValues;\n            break;\n          case 'search':\n            updates[`${section.title.toLowerCase().replace(/\\s+/g, '')}SearchQuery`] = selectedValues;\n            break;\n        }\n\n        updateState(updates);\n      }\n\n      if (onFilterChange) {\n        onFilterChange(sectionId, selectedValues);\n      }\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Filter change failed');\n      errorHandler.handleError(\n        FilterErrorType.STATE_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter change failed',\n        'SIDE_FILTER_CHANGE_FAILED',\n        { sectionId, selectedValues, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [sections, updateState, onFilterChange, errorHandler, handleError]);\n\n  const handleSectionToggle = useCallback((sectionId: string, isExpanded?: boolean) => {\n    try {\n      setExpandedSections(prev => {\n        const newSet = new Set(prev);\n        const shouldExpand = isExpanded ?? !newSet.has(sectionId);\n        \n        if (shouldExpand) {\n          newSet.add(sectionId);\n        } else {\n          newSet.delete(sectionId);\n        }\n        \n        return newSet;\n      });\n\n      if (onSectionToggle) {\n        const expanded = isExpanded ?? !expandedSections.has(sectionId);\n        onSectionToggle(sectionId, expanded);\n      }\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Section toggle failed');\n      errorHandler.handleError(\n        FilterErrorType.STATE_ERROR,\n        FilterErrorSeverity.LOW,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter section toggle failed',\n        'SIDE_FILTER_SECTION_TOGGLE_FAILED',\n        { sectionId, isExpanded, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [expandedSections, onSectionToggle, errorHandler, handleError]);\n\n  // ===== DATA LOADING =====\n\n  const loadFilterData = useCallback(async (targetCategoryId?: string): Promise<boolean> => {\n    try {\n      setIsLoading(true);\n      setError(null);\n\n      const categoryToLoad = targetCategoryId || categoryId;\n      const loadedSections = dataService.getFilterSections(categoryToLoad);\n\n      if (loadedSections.length === 0) {\n        throw new Error(`No filter data found for category: ${categoryToLoad}`);\n      }\n\n      handleDataLoaded(loadedSections);\n      return true;\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Failed to load filter data');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to load side filter data',\n        'LOAD_SIDE_FILTER_DATA_FAILED',\n        { categoryId: targetCategoryId || categoryId, error: errorObj.message }\n      );\n      handleError(errorObj);\n      return false;\n    } finally {\n      setIsLoading(false);\n    }\n  }, [categoryId, dataService, errorHandler, handleError, handleDataLoaded]);\n\n  // ===== FILTER ACTIONS =====\n\n  const applyFilter = useCallback((sectionId: string, selectedValues: string[]) => {\n    handleFilterChange(sectionId, selectedValues);\n  }, [handleFilterChange]);\n\n  const clearFilter = useCallback((sectionId: string) => {\n    handleFilterChange(sectionId, []);\n  }, [handleFilterChange]);\n\n  const clearAllFilters = useCallback(() => {\n    try {\n      setAppliedFilters({});\n      setIsDirty(false);\n      setLastUpdateTime(Date.now());\n\n      clearFilters();\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Clear all filters failed');\n      errorHandler.handleError(\n        FilterErrorType.STATE_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter clear all failed',\n        'SIDE_FILTER_CLEAR_ALL_FAILED',\n        { error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [clearFilters, errorHandler, handleError]);\n\n  const toggleSection = useCallback((sectionId: string, isExpanded?: boolean) => {\n    handleSectionToggle(sectionId, isExpanded);\n  }, [handleSectionToggle]);\n\n  const updateSearchQuery = useCallback((sectionId: string, query: string) => {\n    try {\n      setSearchQueries(prev => ({\n        ...prev,\n        [sectionId]: query\n      }));\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Update search query failed');\n      errorHandler.handleError(\n        FilterErrorType.STATE_ERROR,\n        FilterErrorSeverity.LOW,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter search query update failed',\n        'SIDE_FILTER_SEARCH_QUERY_UPDATE_FAILED',\n        { sectionId, query, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [errorHandler, handleError]);\n\n  const updateSortOrder = useCallback((sectionId: string, order: 'asc' | 'desc' | 'count') => {\n    try {\n      setSortOrders(prev => ({\n        ...prev,\n        [sectionId]: order\n      }));\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Update sort order failed');\n      errorHandler.handleError(\n        FilterErrorType.STATE_ERROR,\n        FilterErrorSeverity.LOW,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter sort order update failed',\n        'SIDE_FILTER_SORT_ORDER_UPDATE_FAILED',\n        { sectionId, order, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [errorHandler, handleError]);\n\n  // ===== DATA MANAGEMENT =====\n\n  const updateFilterSections = useCallback((newSections: SideFilterSection[]) => {\n    try {\n      setSections(newSections);\n      setLastUpdateTime(Date.now());\n\n      // Update data service\n      dataService.updateFilterData(categoryId, { sections: newSections });\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Update filter sections failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter sections update failed',\n        'SIDE_FILTER_SECTIONS_UPDATE_FAILED',\n        { categoryId, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [categoryId, dataService, errorHandler, handleError]);\n\n  const updateFilterOptions = useCallback((sectionId: string, options: SideFilterOption[]) => {\n    try {\n      setSections(prev => prev.map(section =>\n        section.id === sectionId\n          ? { ...section, options }\n          : section\n      ));\n\n      setLastUpdateTime(Date.now());\n\n      // Update data service\n      dataService.updateFilterOptions(categoryId, sectionId, options);\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Update filter options failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter options update failed',\n        'SIDE_FILTER_OPTIONS_UPDATE_FAILED',\n        { categoryId, sectionId, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [categoryId, dataService, errorHandler, handleError]);\n\n  // ===== PRESET MANAGEMENT =====\n\n  const savePreset = useCallback((name: string): string | null => {\n    try {\n      const presetData = {\n        appliedFilters,\n        expandedSections: Array.from(expandedSections),\n        searchQueries,\n        sortOrders\n      };\n\n      const presetId = saveUnifiedPreset(name, presetData);\n      \n      if (presetId) {\n        setSelectedPreset(presetId);\n      }\n\n      return presetId;\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Save preset failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter preset save failed',\n        'SIDE_FILTER_PRESET_SAVE_FAILED',\n        { name, error: errorObj.message }\n      );\n      handleError(errorObj);\n      return null;\n    }\n  }, [appliedFilters, expandedSections, searchQueries, sortOrders, saveUnifiedPreset, errorHandler, handleError]);\n\n  const loadPreset = useCallback((presetId: string): boolean => {\n    try {\n      const success = loadUnifiedPreset(presetId);\n      \n      if (success) {\n        setSelectedPreset(presetId);\n      }\n\n      return success;\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Load preset failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter preset load failed',\n        'SIDE_FILTER_PRESET_LOAD_FAILED',\n        { presetId, error: errorObj.message }\n      );\n      handleError(errorObj);\n      return false;\n    }\n  }, [loadUnifiedPreset, errorHandler, handleError]);\n\n  // ===== DATA EXPORT/IMPORT =====\n\n  const exportData = useCallback((targetCategoryId?: string): string => {\n    try {\n      return dataService.exportFilterData(targetCategoryId || categoryId);\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Export data failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter data export failed',\n        'SIDE_FILTER_DATA_EXPORT_FAILED',\n        { categoryId: targetCategoryId || categoryId, error: errorObj.message }\n      );\n      handleError(errorObj);\n      return '';\n    }\n  }, [categoryId, dataService, errorHandler, handleError]);\n\n  const importData = useCallback((data: string): boolean => {\n    try {\n      return dataService.importFilterData(data);\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Import data failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter data import failed',\n        'SIDE_FILTER_DATA_IMPORT_FAILED',\n        { error: errorObj.message }\n      );\n      handleError(errorObj);\n      return false;\n    }\n  }, [dataService, errorHandler, handleError]);\n\n  // ===== ERROR HANDLING =====\n\n  const clearError = useCallback(() => {\n    setError(null);\n    clearFilterError();\n  }, [clearFilterError]);\n\n  // ===== REFRESH DATA =====\n\n  const refreshData = useCallback(async (): Promise<void> => {\n    try {\n      await loadFilterData();\n      setStatistics(dataService.getFilterStatistics());\n\n    } catch (error) {\n      const errorObj = error instanceof Error ? error : new Error('Refresh data failed');\n      errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Side filter data refresh failed',\n        'SIDE_FILTER_DATA_REFRESH_FAILED',\n        { categoryId, error: errorObj.message }\n      );\n      handleError(errorObj);\n    }\n  }, [categoryId, loadFilterData, dataService, errorHandler, handleError]);\n\n  // ===== EFFECTS =====\n\n  useEffect(() => {\n    if (autoLoadData && categoryId) {\n      loadFilterData();\n    }\n  }, [autoLoadData, categoryId, loadFilterData]);\n\n  useEffect(() => {\n    if (filterError) {\n      setError(filterError);\n    }\n  }, [filterError]);\n\n  useEffect(() => {\n    // Subscribe to data service events\n    const handleDataUpdated = ({ categoryId: updatedCategoryId }: { categoryId: string }) => {\n      if (updatedCategoryId === categoryId) {\n        refreshData();\n      }\n    };\n\n    const handleDataAdded = ({ categoryId: addedCategoryId }: { categoryId: string }) => {\n      if (addedCategoryId === categoryId) {\n        refreshData();\n      }\n    };\n\n    const handleDataRemoved = ({ categoryId: removedCategoryId }: { categoryId: string }) => {\n      if (removedCategoryId === categoryId) {\n        setSections([]);\n        setIsDataInitialized(false);\n      }\n    };\n\n    dataService.on('filterDataUpdated', handleDataUpdated);\n    dataService.on('filterDataAdded', handleDataAdded);\n    dataService.on('filterDataRemoved', handleDataRemoved);\n\n    return () => {\n      dataService.off('filterDataUpdated', handleDataUpdated);\n      dataService.off('filterDataAdded', handleDataAdded);\n      dataService.off('filterDataRemoved', handleDataRemoved);\n    };\n  }, [categoryId, dataService, refreshData]);\n\n  // ===== RETURN VALUE =====\n\n  return {\n    // Data\n    sections,\n    isLoading: isLoading || filterLoading,\n    error: error || filterError,\n    isDataInitialized,\n    dataVersion,\n    statistics,\n\n    // State\n    appliedFilters,\n    expandedSections,\n    searchQueries,\n    sortOrders,\n    selectedPreset,\n    isDirty,\n    lastUpdateTime,\n\n    // Actions\n    loadFilterData,\n    updateFilterSections,\n    updateFilterOptions,\n    applyFilter,\n    clearFilter,\n    clearAllFilters,\n    toggleSection,\n    updateSearchQuery,\n    updateSortOrder,\n    savePreset,\n    loadPreset,\n    exportData,\n    importData,\n    clearError,\n    refreshData\n  };\n}; "],
