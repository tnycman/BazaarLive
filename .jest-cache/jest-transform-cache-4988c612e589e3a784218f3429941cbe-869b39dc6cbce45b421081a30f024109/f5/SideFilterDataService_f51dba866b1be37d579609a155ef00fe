      sourcesContent: ["/**\n * Side Filter Data Service\n * Enterprise-grade data management for side filters\n * 100% best practices, zero shortcuts, enterprise-grade patterns\n */\n\nimport { EventEmitter } from 'events';\nimport { z } from 'zod';\nimport { FilterErrorHandler, FilterErrorType, FilterErrorSeverity, FilterErrorContext } from '@/services/error/FilterErrorHandler';\nimport type { SideFilterSection, SideFilterOption } from '@/components/filters/AdvancedSideFilter';\n\n// ===== DATA SCHEMAS =====\n\nconst FilterOptionSchema = z.object({\n  id: z.string(),\n  label: z.string(),\n  value: z.string(),\n  count: z.number().optional(),\n  isSelected: z.boolean().default(false),\n  isDisabled: z.boolean().optional(),\n  metadata: z.object({\n    color: z.string().optional(),\n    imageUrl: z.string().optional(),\n    description: z.string().optional()\n  }).optional()\n});\n\nconst FilterSectionSchema = z.object({\n  id: z.string(),\n  title: z.string(),\n  type: z.enum(['checkbox', 'radio', 'range', 'search', 'color', 'size']),\n  options: z.array(FilterOptionSchema),\n  isExpanded: z.boolean().default(true),\n  isCollapsible: z.boolean().default(true),\n  maxVisibleOptions: z.number().optional(),\n  showMoreText: z.string().optional(),\n  showLessText: z.string().optional(),\n  placeholder: z.string().optional(),\n  minValue: z.number().optional(),\n  maxValue: z.number().optional(),\n  step: z.number().optional(),\n  unit: z.string().optional()\n});\n\nconst FilterDataSchema = z.object({\n  categoryId: z.string(),\n  sections: z.array(FilterSectionSchema),\n  lastUpdated: z.number(),\n  version: z.string(),\n  metadata: z.record(z.unknown()).optional()\n});\n\nexport interface FilterData extends z.infer<typeof FilterDataSchema> {}\n\n// ===== SIDE FILTER DATA SERVICE =====\n\nexport class SideFilterDataService extends EventEmitter {\n  private static instance: SideFilterDataService;\n  private filterData: Map<string, FilterData> = new Map();\n  private errorHandler: FilterErrorHandler;\n  private isInitialized: boolean = false;\n\n  private constructor() {\n    super();\n    this.errorHandler = FilterErrorHandler.getInstance();\n    this.initializeDefaultData();\n  }\n\n  static getInstance(): SideFilterDataService {\n    if (!SideFilterDataService.instance) {\n      SideFilterDataService.instance = new SideFilterDataService();\n    }\n    return SideFilterDataService.instance;\n  }\n\n  /**\n   * Initialize default filter data for main categories\n   */\n  private initializeDefaultData(): void {\n    try {\n      // Fashion category filters\n      this.filterData.set('fashion', {\n        categoryId: 'fashion',\n        sections: [\n          {\n            id: 'brands',\n            title: 'Brands',\n            type: 'checkbox',\n            options: [\n              { id: 'nike', label: 'Nike', value: 'nike', count: 1250, isSelected: false },\n              { id: 'adidas', label: 'Adidas', value: 'adidas', count: 980, isSelected: false },\n              { id: 'puma', label: 'Puma', value: 'puma', count: 750, isSelected: false },\n              { id: 'reebok', label: 'Reebok', value: 'reebok', count: 620, isSelected: false },\n              { id: 'under-armour', label: 'Under Armour', value: 'under-armour', count: 450, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true,\n            maxVisibleOptions: 5\n          },\n          {\n            id: 'sizes',\n            title: 'Sizes',\n            type: 'checkbox',\n            options: [\n              { id: 'xs', label: 'XS', value: 'xs', count: 320, isSelected: false },\n              { id: 's', label: 'S', value: 's', count: 580, isSelected: false },\n              { id: 'm', label: 'M', value: 'm', count: 890, isSelected: false },\n              { id: 'l', label: 'L', value: 'l', count: 720, isSelected: false },\n              { id: 'xl', label: 'XL', value: 'xl', count: 450, isSelected: false },\n              { id: 'xxl', label: 'XXL', value: 'xxl', count: 280, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'colors',\n            title: 'Colors',\n            type: 'color',\n            options: [\n              { id: 'black', label: 'Black', value: 'black', count: 1200, isSelected: false, metadata: { color: '#000000' } },\n              { id: 'white', label: 'White', value: 'white', count: 980, isSelected: false, metadata: { color: '#FFFFFF' } },\n              { id: 'red', label: 'Red', value: 'red', count: 650, isSelected: false, metadata: { color: '#FF0000' } },\n              { id: 'blue', label: 'Blue', value: 'blue', count: 720, isSelected: false, metadata: { color: '#0000FF' } },\n              { id: 'green', label: 'Green', value: 'green', count: 450, isSelected: false, metadata: { color: '#00FF00' } },\n              { id: 'yellow', label: 'Yellow', value: 'yellow', count: 320, isSelected: false, metadata: { color: '#FFFF00' } }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'price',\n            title: 'Price Range',\n            type: 'range',\n            options: [],\n            minValue: 0,\n            maxValue: 500,\n            step: 10,\n            unit: '$',\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'condition',\n            title: 'Condition',\n            type: 'radio',\n            options: [\n              { id: 'new', label: 'New', value: 'new', count: 2500, isSelected: false },\n              { id: 'like-new', label: 'Like New', value: 'like-new', count: 1800, isSelected: false },\n              { id: 'good', label: 'Good', value: 'good', count: 1200, isSelected: false },\n              { id: 'fair', label: 'Fair', value: 'fair', count: 800, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'availability',\n            title: 'Availability',\n            type: 'checkbox',\n            options: [\n              { id: 'in-stock', label: 'In Stock', value: 'in-stock', count: 3500, isSelected: false },\n              { id: 'pre-order', label: 'Pre-order', value: 'pre-order', count: 450, isSelected: false },\n              { id: 'backorder', label: 'Backorder', value: 'backorder', count: 280, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          }\n        ],\n        lastUpdated: Date.now(),\n        version: '1.0.0'\n      });\n\n      // Electronics category filters\n      this.filterData.set('electronics', {\n        categoryId: 'electronics',\n        sections: [\n          {\n            id: 'brands',\n            title: 'Brands',\n            type: 'checkbox',\n            options: [\n              { id: 'apple', label: 'Apple', value: 'apple', count: 850, isSelected: false },\n              { id: 'samsung', label: 'Samsung', value: 'samsung', count: 720, isSelected: false },\n              { id: 'sony', label: 'Sony', value: 'sony', count: 580, isSelected: false },\n              { id: 'lg', label: 'LG', value: 'lg', count: 420, isSelected: false },\n              { id: 'microsoft', label: 'Microsoft', value: 'microsoft', count: 380, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'price',\n            title: 'Price Range',\n            type: 'range',\n            options: [],\n            minValue: 0,\n            maxValue: 2000,\n            step: 50,\n            unit: '$',\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'condition',\n            title: 'Condition',\n            type: 'radio',\n            options: [\n              { id: 'new', label: 'New', value: 'new', count: 1800, isSelected: false },\n              { id: 'refurbished', label: 'Refurbished', value: 'refurbished', count: 650, isSelected: false },\n              { id: 'used', label: 'Used', value: 'used', count: 420, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          }\n        ],\n        lastUpdated: Date.now(),\n        version: '1.0.0'\n      });\n\n      // Home & Garden category filters\n      this.filterData.set('home', {\n        categoryId: 'home',\n        sections: [\n          {\n            id: 'brands',\n            title: 'Brands',\n            type: 'checkbox',\n            options: [\n              { id: 'ikea', label: 'IKEA', value: 'ikea', count: 650, isSelected: false },\n              { id: 'wayfair', label: 'Wayfair', value: 'wayfair', count: 580, isSelected: false },\n              { id: 'west-elm', label: 'West Elm', value: 'west-elm', count: 420, isSelected: false },\n              { id: 'crate-barrel', label: 'Crate & Barrel', value: 'crate-barrel', count: 380, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'price',\n            title: 'Price Range',\n            type: 'range',\n            options: [],\n            minValue: 0,\n            maxValue: 1000,\n            step: 25,\n            unit: '$',\n            isExpanded: true,\n            isCollapsible: true\n          },\n          {\n            id: 'room',\n            title: 'Room',\n            type: 'checkbox',\n            options: [\n              { id: 'living-room', label: 'Living Room', value: 'living-room', count: 850, isSelected: false },\n              { id: 'bedroom', label: 'Bedroom', value: 'bedroom', count: 720, isSelected: false },\n              { id: 'kitchen', label: 'Kitchen', value: 'kitchen', count: 580, isSelected: false },\n              { id: 'bathroom', label: 'Bathroom', value: 'bathroom', count: 420, isSelected: false },\n              { id: 'dining-room', label: 'Dining Room', value: 'dining-room', count: 380, isSelected: false }\n            ],\n            isExpanded: true,\n            isCollapsible: true\n          }\n        ],\n        lastUpdated: Date.now(),\n        version: '1.0.0'\n      });\n\n      this.isInitialized = true;\n      this.emit('dataInitialized', { timestamp: Date.now() });\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.CONFIGURATION_ERROR,\n        FilterErrorSeverity.HIGH,\n        FilterErrorContext.CONFIGURATION,\n        'Failed to initialize side filter data',\n        'SIDE_FILTER_DATA_INIT_FAILED',\n        { error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n    }\n  }\n\n  /**\n   * Get filter data for a specific category\n   */\n  public getFilterData(categoryId: string): FilterData | null {\n    try {\n      const data = this.filterData.get(categoryId);\n      \n      if (!data) {\n        this.errorHandler.handleError(\n          FilterErrorType.DATA_ERROR,\n          FilterErrorSeverity.MEDIUM,\n          FilterErrorContext.CATEGORY_FILTER,\n          'Filter data not found for category',\n          'FILTER_DATA_NOT_FOUND',\n          { categoryId }\n        );\n        return null;\n      }\n\n      // Validate data\n      const validation = FilterDataSchema.safeParse(data);\n      if (!validation.success) {\n        this.errorHandler.handleError(\n          FilterErrorType.VALIDATION_ERROR,\n          FilterErrorSeverity.HIGH,\n          FilterErrorContext.CATEGORY_FILTER,\n          'Invalid filter data detected',\n          'FILTER_DATA_VALIDATION_FAILED',\n          { categoryId, errors: validation.error.errors }\n        );\n        return null;\n      }\n\n      return validation.data;\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to get filter data',\n        'GET_FILTER_DATA_FAILED',\n        { categoryId, error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return null;\n    }\n  }\n\n  /**\n   * Get filter sections for a category\n   */\n  public getFilterSections(categoryId: string): SideFilterSection[] {\n    try {\n      const data = this.getFilterData(categoryId);\n      return data?.sections || [];\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to get filter sections',\n        'GET_FILTER_SECTIONS_FAILED',\n        { categoryId, error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return [];\n    }\n  }\n\n  /**\n   * Update filter data for a category\n   */\n  public updateFilterData(categoryId: string, data: Partial<FilterData>): boolean {\n    try {\n      const existingData = this.filterData.get(categoryId);\n      if (!existingData) {\n        this.errorHandler.handleError(\n          FilterErrorType.DATA_ERROR,\n          FilterErrorSeverity.MEDIUM,\n          FilterErrorContext.CATEGORY_FILTER,\n          'Cannot update non-existent filter data',\n          'UPDATE_NON_EXISTENT_FILTER_DATA',\n          { categoryId }\n        );\n        return false;\n      }\n\n      const updatedData: FilterData = {\n        ...existingData,\n        ...data,\n        lastUpdated: Date.now()\n      };\n\n      // Validate updated data\n      const validation = FilterDataSchema.safeParse(updatedData);\n      if (!validation.success) {\n        this.errorHandler.handleError(\n          FilterErrorType.VALIDATION_ERROR,\n          FilterErrorSeverity.MEDIUM,\n          FilterErrorContext.CATEGORY_FILTER,\n          'Updated filter data validation failed',\n          'UPDATE_FILTER_DATA_VALIDATION_FAILED',\n          { categoryId, errors: validation.error.errors }\n        );\n        return false;\n      }\n\n      this.filterData.set(categoryId, validation.data);\n\n      this.emit('filterDataUpdated', {\n        categoryId,\n        data: validation.data,\n        timestamp: Date.now()\n      });\n\n      return true;\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to update filter data',\n        'UPDATE_FILTER_DATA_FAILED',\n        { categoryId, error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return false;\n    }\n  }\n\n  /**\n   * Add new filter data for a category\n   */\n  public addFilterData(data: FilterData): boolean {\n    try {\n      // Validate data\n      const validation = FilterDataSchema.safeParse(data);\n      if (!validation.success) {\n        this.errorHandler.handleError(\n          FilterErrorType.VALIDATION_ERROR,\n          FilterErrorSeverity.MEDIUM,\n          FilterErrorContext.CATEGORY_FILTER,\n          'New filter data validation failed',\n          'ADD_FILTER_DATA_VALIDATION_FAILED',\n          { categoryId: data.categoryId, errors: validation.error.errors }\n        );\n        return false;\n      }\n\n      this.filterData.set(data.categoryId, validation.data);\n\n      this.emit('filterDataAdded', {\n        categoryId: data.categoryId,\n        data: validation.data,\n        timestamp: Date.now()\n      });\n\n      return true;\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to add filter data',\n        'ADD_FILTER_DATA_FAILED',\n        { categoryId: data.categoryId, error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return false;\n    }\n  }\n\n  /**\n   * Remove filter data for a category\n   */\n  public removeFilterData(categoryId: string): boolean {\n    try {\n      const existed = this.filterData.has(categoryId);\n      \n      if (existed) {\n        this.filterData.delete(categoryId);\n\n        this.emit('filterDataRemoved', {\n          categoryId,\n          timestamp: Date.now()\n        });\n      }\n\n      return existed;\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to remove filter data',\n        'REMOVE_FILTER_DATA_FAILED',\n        { categoryId, error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return false;\n    }\n  }\n\n  /**\n   * Update filter options for a specific section\n   */\n  public updateFilterOptions(\n    categoryId: string,\n    sectionId: string,\n    options: SideFilterOption[]\n  ): boolean {\n    try {\n      const data = this.getFilterData(categoryId);\n      if (!data) {\n        return false;\n      }\n\n      const updatedSections = data.sections.map(section =>\n        section.id === sectionId\n          ? { ...section, options }\n          : section\n      );\n\n      return this.updateFilterData(categoryId, { sections: updatedSections });\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to update filter options',\n        'UPDATE_FILTER_OPTIONS_FAILED',\n        { categoryId, sectionId, error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return false;\n    }\n  }\n\n  /**\n   * Get all available categories\n   */\n  public getAvailableCategories(): string[] {\n    try {\n      return Array.from(this.filterData.keys());\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.LOW,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to get available categories',\n        'GET_AVAILABLE_CATEGORIES_FAILED',\n        { error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return [];\n    }\n  }\n\n  /**\n   * Get filter statistics\n   */\n  public getFilterStatistics(): Record<string, any> {\n    try {\n      const stats: Record<string, any> = {\n        totalCategories: this.filterData.size,\n        totalSections: 0,\n        totalOptions: 0,\n        categories: {}\n      };\n\n      for (const [categoryId, data] of this.filterData) {\n        const categoryStats = {\n          sections: data.sections.length,\n          options: data.sections.reduce((sum, section) => sum + section.options.length, 0),\n          lastUpdated: data.lastUpdated\n        };\n\n        stats.totalSections += categoryStats.sections;\n        stats.totalOptions += categoryStats.options;\n        stats.categories[categoryId] = categoryStats;\n      }\n\n      return stats;\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.LOW,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to get filter statistics',\n        'GET_FILTER_STATISTICS_FAILED',\n        { error: error instanceof Error ? error.message : 'Unknown error' }\n      );\n      return {};\n    }\n  }\n\n  /**\n   * Export filter data\n   */\n  public exportFilterData(categoryId?: string): string {\n    try {\n      if (categoryId) {\n        const data = this.getFilterData(categoryId);\n        return data ? JSON.stringify(data, null, 2) : '';\n      } else {\n        const allData = Object.fromEntries(this.filterData);\n        return JSON.stringify(allData, null, 2);\n      }\n\n    } catch (error) {\n      this.errorHandler.handleError(\n        FilterErrorType.DATA_ERROR,\n        FilterErrorSeverity.MEDIUM,\n        FilterErrorContext.CATEGORY_FILTER,\n        'Failed to 