M,CAAC,WAAW,CAAC,MAAM,CAAC,CAAC;YAC/C,IAAI,CAAC,MAAM,CAAC,MAAM,CAAC,CAAC,UAAU,EAAE,CAAC;QACnC,CAAC,CAAC,CAAC;IACL,CAAC;CACF;AAED;;GAEG;AACH,MAAM,UAAgB,sCAAsC;;QAC1D,OAAO,CAAC,GAAG,CAAC,8CAA8C,CAAC,CAAC;QAC5D,OAAO,CAAC,GAAG,CAAC,GAAG,CAAE,MAAM,CAAC,EAAE,CAAC,CAAC,CAAC;QAE7B,MAAM,SAAS,GAAG,IAAI,mCAAmC,EAAE,CAAC;QAC5D,MAAM,SAAS,CAAC,GAAG,EAAE,CAAC;IACxB,CAAC;CAAA;AAED,0BAA0B;AAC1B,IAAI,OAAO,MAAM,KAAK,WAAW,EAAE,CAAC;IAClC,sCAAsC,EAAE,CAAC,KAAK,CAAC,OAAO,CAAC,KAAK,CAAC,CAAC;AAChE,CAAC;AAED,OAAO,EAAE,mCAAmC,EAAE,CAAC",
