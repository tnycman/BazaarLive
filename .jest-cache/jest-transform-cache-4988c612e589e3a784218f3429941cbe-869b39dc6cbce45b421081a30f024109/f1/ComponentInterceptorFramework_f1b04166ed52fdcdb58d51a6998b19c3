AAkD,CAAC;AAC5D,CAAC;AAgDD,wBAAwB;AACxB,MAAM,8BAA8B,GAA0B;IAC5D,YAAY,EAAE,EAAE,EAAE,eAAe;IACjC,aAAa,EAAE,EAAE;IACjB,cAAc,EAAE,EAAE,GAAG,IAAI,GAAG,IAAI,CAAC,OAAO;CACzC,CAAC;AAEF,+BAA+B;AAC/B,MAAM,CAAC,MAAM,wBAAwB,GAAG,IAAI,4BAA4B,EAAE,CAAC;AAE3E,gCAAgC;AAChC,wBAAwB,CAAC,mBAAmB,CAAC,IAAI,gCAAgC,EAAE,CAAC,CAAC;AACrF,wBAAwB,CAAC,mBAAmB,CAAC,IAAI,0BAA0B,EAAE,CAAC,CAAC;AAC/E,wBAAwB,CAAC,mBAAmB,CAAC,IAAI,wBAAwB,EAAE,CAAC,CAAC",
      names: [],
