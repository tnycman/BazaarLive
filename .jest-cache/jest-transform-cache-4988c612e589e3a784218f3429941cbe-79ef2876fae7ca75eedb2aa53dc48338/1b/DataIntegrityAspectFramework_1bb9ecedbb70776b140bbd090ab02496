E,GAAG,SAAS;gBAC5C,WAAW,EAAE,CAAA,MAAC,WAAmB,CAAC,MAAM,0CAAE,cAAc,KAAI,CAAC;gBAC7D,cAAc,EAAE,CAAC;gBACjB,gBAAgB,EAAE,CAAC;aACpB,CAAC;YAEF,OAAO;gBACL,OAAO,EAAE,KAAK;gBACd,KAAK,EAAE,EAAS;gBAChB,KAAK,EAAE,IAAI,wBAAwB,CACjC,sDAAuD,KAAe,CAAC,OAAO,EAAE,EAChF;oBACE,OAAO;oBACP,aAAa,EAAE,KAAK;oBACpB,WAAW;oBACX,WAAW;iBACZ,CACF;gBACD,QAAQ,EAAE,IAAI,CAAC,cAAc,CAAC,IAAI,CAAC,IAAI,EAAE,WAAW,EAAE,OAAO,EAAE,CAAC,cAAc,CAAC,EAAE,kBAAkB,CAAC;gBACpG,WAAW;aACZ,CAAC;QACJ,CAAC;IACH,CAAC;CACF;AAED,wCAAwC;AACxC,MAAM,CAAC,MAAM,mBAAmB,GAAG,IAAI,6BAA6B,EAAE,CAAC",
